APP_NAME=internal-mobility-matching
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=4004
LOG_LEVEL=INFO

# Database (same warehouse Postgres instance as llm-engine; own schema)
DATABASE_URL=postgresql+asyncpg://postgres:password@host.docker.internal:35432/warehouse
SYNC_DATABASE_URL=postgresql://postgres:password@host.docker.internal:35432/warehouse
CELERY_DATABASE_BACKEND_URL=db+postgresql://postgres:password@host.docker.internal:35432/warehouse
DATABASE_SCHEMA=better_sense

# Celery / broker
REDIS_BROKER_ENABLED=true
REDIS_BROKER_URL=redis://redis:6379/0
CELERY_TASK_DEFAULT_QUEUE=local-internal-mobility-matching-celery

# LLM Proxy
OPENAI_API_KEY=<openai-api-key>
LLM_PROXY_URL=https://rainforest.betterworks.com/services/llm-proxy/v1
LLM_PROXY_TOKEN=<llm-proxy-token>
LLM_PROXY_ENABLED=true
PRIVATE_LLM_MODEL=meta/llama3.1

# Embedding service (embeds the JD query vector; reachable on the host at :6005,
# so containers use host.docker.internal)
BW_EMBEDDING_URL=http://host.docker.internal:6005
EMBEDDING_MODEL=embeddinggemma-300m
EMBEDDING_TIMEOUT_SECONDS=120
